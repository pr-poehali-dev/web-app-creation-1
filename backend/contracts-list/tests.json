{
  "tests": [
    {
      "name": "Get all contracts",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"limit": 50, "offset": 0}
    },
    {
      "name": "GET open contracts by limit",
      "method": "GET",
      "path": "/?status=open&limit=5",
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"limit": 5}
    },
    {
      "name": "GET contract by id",
      "method": "GET",
      "path": "/?id=1",
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {}
    },
    {
      "name": "DELETE contract without auth returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "deleteContract", "contractId": 999},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {}
    },
    {
      "name": "POST respond without auth returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "respond", "contractId": 10, "pricePerUnit": 26000, "totalAmount": 52000, "comment": ""},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {}
    }
  ]
}