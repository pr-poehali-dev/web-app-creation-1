{
  "tests": [
    {
      "name": "Get statistics for month period",
      "method": "GET",
      "path": "/?period=month",
      "headers": {
        "X-User-Id": "81"
      },
      "expectedStatus": 200,
      "expectedBody": {
        "period": "month"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Get statistics for custom period",
      "method": "GET",
      "path": "/?period=custom&start_date=2024-01-01&end_date=2024-12-31",
      "headers": {
        "X-User-Id": "81"
      },
      "expectedStatus": 200,
      "expectedBody": {
        "period": "custom",
        "date_range": {
          "start": "2024-01-01",
          "end": "2024-12-31"
        }
      },
      "bodyMatcher": "partial"
    }
  ]
}
